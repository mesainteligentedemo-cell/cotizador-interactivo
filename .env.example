# === Resend (envío real de correo) ===
# Crea una API key en https://resend.com/api-keys
# Si se omite, /api/email/send funciona en modo "sandbox": simula el envío sin fallar el flujo.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Remitente verificado en Resend (dominio propio o el de pruebas onboarding@resend.dev)
RESEND_FROM_EMAIL="Cotizador SYSCOM <onboarding@resend.dev>"

# === Google Sheets (guardar cotizaciones) ===
# Cuenta de servicio de Google Cloud (IAM > Service Accounts) con acceso a Sheets API.
# Comparte el Google Sheet de destino con este correo como Editor.
GOOGLE_SHEETS_CLIENT_EMAIL=nombre-cuenta-servicio@proyecto.iam.gserviceaccount.com
# Private key del JSON de la cuenta de servicio. En Vercel, pega el valor completo
# incluyendo -----BEGIN PRIVATE KEY-----...-----END PRIVATE KEY-----\n (con \n literales).
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"
# ID del spreadsheet (se toma de la URL: https://docs.google.com/spreadsheets/d/ESTE_ID/edit)
GOOGLE_SHEETS_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx